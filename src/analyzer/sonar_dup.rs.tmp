#[cfg(test)]
mod debug_tests {
    use super::*;

    #[test]
    fn debug_big_match() {
        let body = "  const x = 1;\n  const y = 2;\n  const z = x + y;\n  const a = x * y;\n  const b = x - y;\n  const c = x / y;\n  const d = x % y;\n  const e = x & y;\n  const f = x | y;\n  const g = x ^ y;\n  const h = x << y;\n  const i = x >> y;\n  const j = x >>> y;\n  return z;\n";
        let source_a = format!("function foo() {{\n{}}}", body);
        let source_b = format!("function bar() {{\n{}}}", body);
        let toks_a = crate::analyzer::tokenize::tokenize(&source_a);
        let toks_b = crate::analyzer::tokenize::tokenize(&source_b);
        let path_a = PathBuf::from("a.ts");
        let path_b = PathBuf::from("b.ts");
        let report = detect_sonar_sq(
            &[(path_a.clone(), toks_a), (path_b.clone(), toks_b)],
            5,
            false,
        );
        println!("Total lines: {}", report.total_tokens);
        println!("Dup lines: {}", report.duplicated_tokens);
        println!("Percent: {:.2}%", report.duplication_percent);
        println!("Blocks: {}", report.blocks.len());
        for b in &report.blocks {
            println!("  {} tokens:", b.token_count);
            for o in &b.occurrences {
                println!("    {}:{}-{}", o.file.display(), o.start_line, o.end_line);
            }
        }
    }
}
